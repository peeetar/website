---

<div id="employer-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="width:100vw; max-width:none;">
  <div class="absolute inset-0 bg-black/75" style="width:100vw; height:100vh;" onclick="window.hideEmployerModal && window.hideEmployerModal()"></div>

  <div id="employer-panel" class="relative w-full max-w-xl mx-4 bg-background text-foreground rounded-lg shadow-lg p-6 transform" role="dialog" aria-modal="true" aria-labelledby="employer-modal-title">
    <button class="absolute top-3 right-3 text-2xl leading-none opacity-70 hover:opacity-100" onclick="window.hideEmployerModal && window.hideEmployerModal()">&times;</button>
    <!-- title removed -->

    <div class="mb-4 space-y-2">
      <p><strong>Available:</strong> June 26 - Sep 26 (Full time, on-site)<br>Ability to continue remote and part-time after September.</p>
      <p><strong>Location:</strong> Thessaloniki, open to relocate.</p>
      <p><strong>Area:</strong> Junior Web Dev, Cybersec Intern, General IT helper.</p>
    </div>

    <div class="flex gap-3 justify-center w-full">
      <a href="/cv.pdf" download class="inline-block px-4 py-2 border border-green-500 text-green-500 rounded hover:bg-green-50">Download CV (EN)</a>
    </div>
  </div>
</div>

<script type="module">
  const modal = document.getElementById('employer-modal');
  const panel = document.getElementById('employer-panel');

  // Ensure initial hidden state uses inline display for reliability
  if (modal) modal.style.display = 'none';
  if (panel) {
    panel.style.opacity = '0';
    panel.style.transform = 'scale(0.95)';
  }

  window.showEmployerModal = () => {
    if (!modal || !panel) return;
    modal.style.display = 'flex';
    // prepare animation
    panel.style.transition = 'transform 180ms ease, opacity 180ms ease';
    // kick off animation on next frame
    requestAnimationFrame(() => {
      panel.style.transform = 'scale(1)';
      panel.style.opacity = '1';
      document.body.style.overflow = 'hidden';
    });
  };

  window.hideEmployerModal = () => {
    if (!modal || !panel) return;
    panel.style.transform = 'scale(0.95)';
    panel.style.opacity = '0';
    setTimeout(() => {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }, 200);
  };
</script>
