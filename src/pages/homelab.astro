---
import Header from '../components/Header.astro';
import Project from "../components/Project.astro";
import Sidebar from "../components/Sidebar.astro";
const projects = [
  {
    title: "Front-end stack",
    desc: [
      "All-encompassing front-end dashboard using Homarr for home lab management",
      "Accessible through a Tailscale tunnel, ensuring secure remote access",
      "Also managable via a customized Android Tablet dashboard setup",
    ],
    tech: ["Proxmox", "Astro", "Android", "Homarr", "HTML", "CSS"]
  },
  {
    title: "Back-end stack",
    desc: [
      "",
      "",
      "",
    ],
    tech: ["", "", "", "", ""]
  }
];
---

<!DOCTYPE html>
<html
>
  <Header title="Homelab Stack | Petar Velkovski" />
  <body>
    <div class="content">
        <Sidebar selectedItem="homelab" />
      <nav class="main">
        <div class="container">
          <div class="back-nav-container">
            <a href="/" class="back-nav-button w-inline-block"
              ><img src="/assets/back.svg" loading="lazy" alt="" class="back-nav-img" />
              <div>Back</div></a
            >
          </div>
          <div class="content-container">
            <h1>Homelab Stack</h1>
            <section class="items-container">
                <div class="resouce-items">
                    {projects.map(project => (
                      <Project 
                        title={project.title} 
                        desc={project.desc}
                        tech={project.tech}
                      />
                    ))}
                  </div>
            </section>
          </div>
        </div>
      </nav>
    </div>

    <!--[if lte IE 9]><script src="//cdnjs.cloudflare.com/ajax/libs/placeholders/3.0.2/placeholders.min.js"></script><![endif]-->
  </body>
</html>
