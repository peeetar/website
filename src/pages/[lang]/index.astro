---
export const getStaticPaths = () => {
  return [
    { params: { lang: "en" } },
  ];
};

import Layout from "@/src/layouts/Layout.astro";
import { useI18n } from "@ariaskit/astro-i18n";
import { type LocaleSchema } from "@/src/types";
import Header from "@/src/components/Header.astro";
import Hero from "@/src/components/Hero.astro";
import Projects from "@/src/components/Projects.astro";
import Experience from "@/src/components/Experience.astro";
import Footer from "@/src/components/Footer.astro";
import Skills from "@/src/components/Skills.astro";
import I18NDebug from "@ariaskit/astro-i18n/I18NDebug.astro";

const { t, locale } = useI18n<LocaleSchema>({
  ssg: {
    astro: Astro,
  },
});

const safeT = (key: string) => {
  try {
    return t(key);
  } catch (e) {
    console.error("i18n: translation error for key:", key, e);
    return "";
  }
};

const nav = [
  { path: `/`, text: safeT("nav.about") },
  { path: `#${safeT("nav.experience")}`, text: safeT("nav.experience") },
  { path: `#${safeT("nav.projects")}`, text: safeT("nav.projects") },
  { path: `#${safeT("nav.contact")}`, text: safeT("nav.contact") },
];

const heroProps = {
  name: "Petar Velkovski",
  title: { key: "hero.title", value: safeT("hero.title") },
  p1: { key: "hero.p1", value: safeT("hero.p1") },
  p2: { key: "hero.p2", value: safeT("hero.p2") },
  p3: { key: "hero.p3", value: safeT("hero.p3") },
};

const _rawLanguages = [
  {
    nameKey: "languages.item_1.name",
    descriptionKey: "languages.item_1.description",
    name: safeT("languages.item_1.name"),
    description: safeT("languages.item_1.description"),
  },
  {
    nameKey: "languages.item_2.name",
    descriptionKey: "languages.item_2.description",
    name: safeT("languages.item_2.name"),
    description: safeT("languages.item_2.description"),
  },
  {
    nameKey: "languages.item_3.name",
    descriptionKey: "languages.item_3.description",
    name: safeT("languages.item_3.name"),
    description: safeT("languages.item_3.description"),
  },
  {
    nameKey: "languages.item_4.name",
    descriptionKey: "languages.item_4.description",
    name: safeT("languages.item_4.name"),
    description: safeT("languages.item_4.description"),
  },
  {
    nameKey: "languages.item_5.name",
    descriptionKey: "languages.item_5.description",
    name: safeT("languages.item_5.name"),
    description: safeT("languages.item_5.description"),
  },
  {
    nameKey: "languages.item_6.name",
    descriptionKey: "languages.item_6.description",
    name: safeT("languages.item_6.name"),
    description: safeT("languages.item_6.description"),
  },
];

const languages = _rawLanguages.filter((p) => {
  return [p.name, p.description].some((v) => typeof v === 'string' && v.trim() !== '');
});

const languagesProps = {
  title: { key: "languages.title", value: safeT("languages.title") },
  projects: languages,
};

const _rawProjects = [
  {
    nameKey: "projects.item_1.name",
    descriptionKey: "projects.item_1.description",
    name: safeT("projects.item_1.name"),
    description: safeT("projects.item_1.description"),
    link: safeT("projects.item_1.link"),
