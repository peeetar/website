    category: { key: "skills.typescript.category", value: safeT("skills.typescript.category") },
    description: { key: "skills.typescript.description", value: safeT("skills.typescript.description") },
    experience_years: { key: "skills.typescript.experience_years", value: safeT("skills.typescript.experience_years") },
    experience_label: { key: "skills.typescript.experience_label", value: safeT("skills.typescript.experience_label") },
