---

<Layout
  locale={locale}
  title="Petar Velkovski"
  description={safeT("description")}
  alternateLinks={alternate}
>
  <Header nav={nav} locales={["en"]} currentLocale={locale} />

  <main>
    <Hero {...heroProps} />
    <section id={languagesProps.title.value.toLowerCase()} class="scroll-mt-50 mt-10">
      <I18NDebug key={languagesProps.title.key}>
        <h2 class="opacity-50 uppercase mb-6">{languagesProps.title.value}</h2>
      </I18NDebug>
      <table class="w-full text-left">
        <tbody>
          {languages.reduce((rows, lang, idx) => {
            if (idx % 2 === 0) rows.push([lang]);
            else rows[rows.length - 1].push(lang);
            return rows;
          }, []).map((pair) => (
            <tr>
              {pair.map((item) => (
                <td class="py-2 pr-4">
                  <strong>{item.name}</strong><br />
                  <span class="opacity-50 text-[0.88rem]">{item.description}</span>
                </td>
              ))}
              {pair.length === 1 ? <td /> : null}
            </tr>
          ))}
        </tbody>
      </table>
    </section>
    <Projects {...projectsProps} />
    <Experience {...experienceData} />
    <Skills heading={{key: "skills.heading", value: safeT("skills.heading")}} content={skills} />
  </main>

  <Footer {...footerContent} />
</Layout>
