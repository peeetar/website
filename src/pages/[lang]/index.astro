  },
  {
    period: { key: "experience.item_4.period", value: safeT("experience.item_4.period") },
    role: { key: "experience.item_4.role", value: safeT("experience.item_4.role") },
    company: { key: "experience.item_4.company", value: safeT("experience.item_4.company") },
    description: { key: "experience.item_4.description", value: safeT("experience.item_4.description") },
  },
];

const jobs = _rawExperienceJobs.filter((job) => {
  const vals = [job.period?.value, job.role?.value, job.company?.value, job.description?.value];
  return vals.some((v) => typeof v === "string" && v.trim() !== "");
});

const experienceData = {
  title: { key: "experience.title", value: safeT("experience.title") },
  jobs,
};

const alternate = [
  { href: "/en", hreflang: "en" },
];

const footerContent = {
  id: safeT("nav.contact").toLowerCase(),
  status: {
